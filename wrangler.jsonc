{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aether",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-02-28",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },

  "env": {
    "staging": {
      "name": "aether-stg",
      "routes": [
        { "pattern": "aether-stg.berlayar.ai", "custom_domain": true }
      ],
      "r2_buckets": [
        {
          "binding": "AETHER_ASSETS",
          "bucket_name": "aether-stg-assets",
          "preview_bucket_name": "aether-stg-assets"
        }
      ],
      "vars": {
        "AETHER_ENV": "staging",
        "NEXT_PUBLIC_AETHER_PUBLIC_DOMAIN": "aether-stg.berlayar.ai",
        "NEXT_PUBLIC_CONVEX_URL": "https://oceanic-dolphin-808.convex.cloud",
        "VOICE_PROVIDER": "openai-realtime",
        "OPENAI_REALTIME_MODEL": "gpt-4o-realtime-preview",
        "OPENAI_REALTIME_VOICE": "alloy",
        "GEMINI_LIVE_MODEL": "gemini-2.5-flash-native-audio-preview-12-2025",
        "GEMINI_LIVE_VOICE": "Kore",
        "SAM3_MODAL_URL": "https://berlayar-ai--aether-sam3.modal.run",
        "SEGMENTATION_PROVIDER": "sam3",
        "VIDEO_PROVIDER": "hyperframes"
      }
    },
    "production": {
      "name": "aether",
      "routes": [
        { "pattern": "aether.berlayar.ai", "custom_domain": true }
      ],
      "r2_buckets": [
        {
          "binding": "AETHER_ASSETS",
          "bucket_name": "aether-assets",
          "preview_bucket_name": "aether-assets"
        }
      ],
      "vars": {
        "AETHER_ENV": "production",
        "NEXT_PUBLIC_AETHER_PUBLIC_DOMAIN": "aether.berlayar.ai",
        "NEXT_PUBLIC_CONVEX_URL": "https://oceanic-dolphin-808.convex.cloud",
        "VOICE_PROVIDER": "openai-realtime",
        "OPENAI_REALTIME_MODEL": "gpt-4o-realtime-preview",
        "OPENAI_REALTIME_VOICE": "alloy",
        "GEMINI_LIVE_MODEL": "gemini-2.5-flash-native-audio-preview-12-2025",
        "GEMINI_LIVE_VOICE": "Kore",
        "SAM3_MODAL_URL": "https://berlayar-ai--aether-sam3.modal.run",
        "SEGMENTATION_PROVIDER": "sam3",
        "VIDEO_PROVIDER": "hyperframes"
      }
    }
  }
}

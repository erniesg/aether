# Copy to .env.postiz (gitignored) and fill in before running deploy.sh.
# All values are passed as Cloud Run secrets or env vars — never baked into the image.

# ── Cloud infra ──────────────────────────────────────────────────────────────
GCLOUD_PROJECT=your-gcp-project-id
GCLOUD_REGION=asia-southeast1           # change to your nearest region
CLOUD_RUN_SERVICE=postiz
CLOUD_RUN_IMAGE=ghcr.io/gitroomhq/postiz-app:latest

# ── Postgres (Cloud SQL) ──────────────────────────────────────────────────────
# DATABASE_URL is GENERATED by deploy.sh — do not set it here.
# deploy.sh provisions the postiz SQL user with a fresh random password,
# constructs the URL using the project/region/instance + Cloud SQL proxy
# format, and pushes it to Secret Manager. Re-runs rotate the password.

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Upstash gives you a rediss:// URI from the console.
REDIS_URL=rediss://default:changeme@your-endpoint.upstash.io:6379

# ── Postiz app ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-hex-string
BACKEND_INTERNAL_URL=https://postiz-HASH-uc.a.run.app   # fill after first deploy
NEXT_PUBLIC_BACKEND_URL=https://postiz-HASH-uc.a.run.app
FRONTEND_URL=https://postiz-HASH-uc.a.run.app           # same value, used by next.js
STORAGE_PROVIDER=local                                   # or s3 — see postiz docs

# ── Per-platform OAuth pairs ──────────────────────────────────────────────────
# Create an OAuth app in each platform's developer portal, then paste the
# client_id / client_secret here. Postiz uses these to connect integrations.

# Instagram & Facebook (both via Meta Developer — same app)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# X (Twitter) — https://developer.x.com/
X_CLIENT_ID=
X_CLIENT_SECRET=

# LinkedIn — https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok — https://developers.tiktok.com/
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Pinterest — https://developers.pinterest.com/
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# YouTube (Google Cloud OAuth) — https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
